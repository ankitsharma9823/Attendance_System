{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler", // Fixed casing

    "rootDir": "./", // Changed from ./src to ./ to include prisma folder
    "outDir": "./dist",

    "strict": true,
    "esModuleInterop": true,

    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "types": ["node"]
  },
  "include": ["src", "prisma","zklib-js.d.ts"] // Added prisma folder here
}