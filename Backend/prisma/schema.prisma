generator client {
  provider = "prisma-client"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

model Employee {
  id         String       @id
  name       String
  department String?
  records    WorkRecord[]
}

model WorkRecord {
  id         Int       @id @default(autoincrement())
  employeeId String
  date       DateTime
  checkIn    DateTime?
  checkOut   DateTime?
  breakIn    DateTime?
  breakOut   DateTime?
  status     String
  overtime   Int       @default(0)
  isOvertime Boolean   @default(false)
  isHalfDay  Boolean   @default(false)
  deviceIp   String?
  totalHours Float     @default(0.0)
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([employeeId, checkIn])
}

model User {
  id                      Int       @id @default(autoincrement())
  username                String    @unique
  email                   String    @unique
  password                String
  role                    String    @default("user")
  emailVerified           Boolean   @default(false)
  emailVerificationCode   String?
  emailVerificationExpiry DateTime?
  passwordResetToken      String?
  passwordResetExpiry     DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
}

model AttendanceSchedule {
  id                  Int      @id @default(1)
  checkInStart        String
  checkInEnd          String
  breakInStart        String
  breakInEnd          String
  breakOutStart       String
  breakOutEnd         String
  checkOutStart       String
  checkOutEnd         String
  minIntervalMinutes  Int      @default(5)
  halfDayMinutes      Int      @default(240)
  maxPunchesPerDay    Int      @default(4)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}
model SyncLog {
  id        Int      @id @default(autoincrement())
  logId     String   @unique // The unique ID provided by the device log
  processedAt DateTime @default(now())
}